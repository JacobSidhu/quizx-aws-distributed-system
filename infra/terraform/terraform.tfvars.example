public_subnet_cidr = "10.0.1.0/24"

project_name      = "your-project-name"
aws_region        = "eu-west-2"
availability_zone = "eu-west-2a"
aws_profile       = "default"

# Network configuration
vpc_cidr                 = "10.0.0.0/16"
vpc_enable_dns_support   = true
vpc_enable_dns_hostnames = true
public_route_config      = { cidr_block = "0.0.0.0/0" }

allowed_ssh_cidr  = "YOUR_PUBLIC_IP/32"
question_app_cidr = "0.0.0.0/0"
submit_app_cidr   = "0.0.0.0/0"

ssh_port          = 22
question_app_port = 4000
submit_app_port   = 4200

# Instance configuration
aws_ami_id          = "ami-xxxxxxxxxxxxxxxxx"
instance_type       = "t3.micro"
ssh_public_key_path = "~/.ssh/your-key-name.pub"